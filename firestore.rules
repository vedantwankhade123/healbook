rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // Helper Functions
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() { return hasRole('admin'); }
    function isDoctor() { return hasRole('doctor'); }
    function isPatient() { return hasRole('patient'); }

    // ---------------------------------------------------------
    // 1. Users Collection
    // ---------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || 
                   isAdmin() || 
                   isDoctor() || // Allow any doctor to read users (needed for patient discovery/history)
                   (resource != null && resource.data.role == 'doctor');
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 2. Doctors Collection
    // ---------------------------------------------------------
    match /doctors/{doctorId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (isDoctor() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 3. Appointments Collection
    // ---------------------------------------------------------
    match /appointments/{appointmentId} {
      // Broad read for appointments: needs to be allowed for booking (slots check) and dashboards
      allow read: if isSignedIn(); 
      
      allow create: if isPatient();
      allow update: if isSignedIn() && (
        resource.data.patientId == request.auth.uid || 
        resource.data.doctorId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 4. Medical Records
    // ---------------------------------------------------------
    match /medical_records/{recordId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isDoctor() || 
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ---------------------------------------------------------
    // 5. Reviews, Notifications, etc.
    // ---------------------------------------------------------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isPatient();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isSignedIn();
    }

    match /logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
